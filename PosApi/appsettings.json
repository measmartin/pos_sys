{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:5010",
  "Jwt": {
    "Key": "",
    "Issuer": "PosApi",
    "Audience": "PosApi-Clients",
    "ExpiresInMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Auth": {
    "EnableRegistration": false
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "ImageSettings": {
    "MaxFileSizeBytes": 1048576,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".webp"],
    "ImageFolder": "wwwroot/images/products",
    "MaxWidth": 1920,
    "MaxHeight": 1920,
    "Quality": 80
  }
}
